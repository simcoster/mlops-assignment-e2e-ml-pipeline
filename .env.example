NEBIUS_API_KEY=XXX

# Agent spend guardrails (used when DAG cost_limit is missing or <= 0)
AGENT_COST_LIMIT_DEFAULT=1.0
# Optional hard caps; derived from cost_limit when unset
# AGENT_CALL_LIMIT=20
# AGENT_STEP_LIMIT=20
# AGENT_CALLS_PER_DOLLAR=20

# MLflow (standalone: localhost; docker compose: http://mlflow:5000 from Airflow containers)
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# Docker Compose / DockerOperator
# Absolute host path to this repo (required for docker compose bind mounts)
PIPELINE_HOST_ROOT=/home/you/airflow-swebench-benchmark
# PIPELINE_IMAGE=mlops-pipeline:latest
AIRFLOW_UID=50000
DOCKER_GID=986
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
# AIRFLOW__CORE__FERNET_KEY=generate-with-python-cryptography-fernet

# Optional: upload runs/<run-id>/ as a tarball to S3-compatible object storage (MinIO in docker compose)
S3_BUCKET=mlops-runs
S3_PREFIX=runs
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://minio:9000
# For local tools outside docker compose, use http://127.0.0.1:9000 instead.
# ARTIFACTS_S3_URI=s3://mlops-runs/runs
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
